# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=AegisAI
DEBUG=true
API_V1_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aegisai_db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Stripe (optional — leave blank to run without billing) ────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=

# ── LLM Provider (OpenAI-compatible — works with any provider) ────────────────
# Used by both the Guard module (prompt responses) and the RAG module (QA chain).
#
# Option A — OpenAI (default):
#   LLM_API_KEY=sk-...
#   LLM_BASE_URL=           ← leave empty
#   LLM_MODEL=gpt-4o-mini
#
# Option B — Ollama (local, free, no API key needed):
#   LLM_API_KEY=ollama
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL=llama3.2      ← or mistral, phi3, gemma2 …
#
# Option C — Groq (free tier, fast):
#   LLM_API_KEY=gsk_...
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_MODEL=llama-3.3-70b-versatile
#
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini

# ── Module 2: LLM Guard ───────────────────────────────────────────────────────
GUARD_SANITIZATION_LEVEL=medium
GUARD_MAX_PROMPT_LENGTH=2000

# ── Module 3: RAG Intelligence ────────────────────────────────────────────────
S3_BUCKET_NAME=
FAISS_INDEX_PATH=faiss_index
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
